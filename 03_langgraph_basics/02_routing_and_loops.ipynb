   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Conditional Edges, Routing & Loops\n",
    "\n",
    "LangGraph's power comes from **conditional edges** that route execution dynamically based on state.\n",
    "\n",
    "Topics:\n",
    "- `add_conditional_edges(source, routing_fn, mapping)` — the core routing primitive\n",
    "- **Basic routing**: classify → dispatch to different handler nodes\n",
    "- **Conditional loop**: evaluate → improve → evaluate (retry until quality threshold)\n",
    "- **Multi-path routing**: combine multiple state fields to pick a handler\n",
    "- **Self-correcting agents**: generate → validate → (re-generate if needed)\n",
    "- **Iterative research**: go deeper on a topic until max depth"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import operator\n",
    "from typing import Literal\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv()\n",
    "\n",
    "from langchain.chat_models import init_chat_model\n",
    "from langchain_core.messages import HumanMessage, SystemMessage\n",
    "from langgraph.graph import StateGraph, START, END\n",
    "from typing_extensions import TypedDict, Annotated\n",
    "\n",
    "llm = init_chat_model(\"gpt-4o-mini\", temperature=0)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Basic Routing\n",
    "\n",
    "```\n",
    "START → classify → [conditional] → handle_question\n",
    "                               ↘ → handle_command\n",
    "                               ↘ → handle_statement\n",
    "```\n",
    "\n",
    "`add_conditional_edges(source, fn, mapping)` calls `fn(state)` and uses the return value to look up the next node in `mapping`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class RouterState(TypedDict):\n",
    "    query: str\n",
    "    query_type: str\n",
    "    response: str\n",
    "\n",
    "def classify_query(state: RouterState) -> dict:\n",
    "    resp = llm.invoke(f\"Classify as 'question', 'command', or 'statement'. Reply with just the word.\\n\\n{state['query']}\")\n",
    "    return {\"query_type\": resp.content.lower().strip()}\n",
    "\n",
    "def handle_question(state: RouterState)  -> dict: return {\"response\": f\"[Answer] {llm.invoke(state['query']).content}\"}\n",
    "def handle_command(state: RouterState)   -> dict: return {\"response\": f\"[Executing] I'll help with: {state['query']}\"}\n",
    "def handle_statement(state: RouterState) -> dict: return {\"response\": f\"[Acknowledged] Thanks for sharing: {state['query']}\"}\n",
    "\n",
    "def route_by_type(state: RouterState) -> Literal[\"question\", \"command\", \"statement\"]:\n",
    "    qt = state[\"query_type\"]\n",
    "    if \"question\" in qt: return \"question\"\n",
    "    if \"command\"  in qt: return \"command\"\n",
    "    return \"statement\"\n",
    "\n",
    "g = StateGraph(RouterState)\n",
    "g.add_node(\"classify\",         classify_query)\n",
    "g.add_node(\"handle_question\",  handle_question)\n",
    "g.add_node(\"handle_command\",   handle_command)\n",
    "g.add_node(\"handle_statement\", handle_statement)\n",
    "\n",
    "g.add_edge(START, \"classify\")\n",
    "g.add_conditional_edges(\n",
    "    \"classify\",       # source node\n",
    "    route_by_type,    # routing function — returns a string key\n",
    "    {\"question\": \"handle_question\", \"command\": \"handle_command\", \"statement\": \"handle_statement\"},\n",
    ")\n",
    "for node in [\"handle_question\", \"handle_command\", \"handle_statement\"]:\n",
    "    g.add_edge(node, END)\n",
    "\n",
    "app = g.compile()\n",
    "\n",
    "for query in [\"What is the capital of France?\", \"Send an email to John\", \"I love programming\"]:\n",
    "    result = app.invoke({\"query\": query, \"query_type\": \"\", \"response\": \"\"})\n",
    "    print(f\"Query: {query}\")\n",
    "    print(f\"Type:  {result['query_type']}\")\n",
    "    print(f\"Resp:  {result['response'][:100]}\")\n",
    "    print()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Conditional Loop — Quality Improvement\n",
    "\n",
    "```\n",
    "START → evaluate → [conditional] ─ score ≥ 7 ─► finalize → END\n",
    "                            └─ score < 7 ─► improve ──┘ (loop back)\n",
    "                            └─ iter ≥ 3  ─► finalize (safety limit)\n",
    "```\n",
    "\n",
    "The loop back edge `improve → evaluate` is what makes this an **agentic cycle**. The `iteration` counter is the safety guard."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class QualityState(TypedDict):\n",
    "    content: str\n",
    "    quality_score: int\n",
    "    feedback: str\n",
    "    final_content: str\n",
    "    iteration: int\n",
    "\n",
    "def evaluate_quality(state: QualityState) -> dict:\n",
    "    resp = llm.invoke(f\"Rate content quality 1-10. Reply with just the number.\\n\\n{state['content']}\")\n",
    "    try:   score = int(resp.content.strip())\n",
    "    except: score = 5\n",
    "    return {\"quality_score\": score}\n",
    "\n",
    "def improve_content(state: QualityState) -> dict:\n",
    "    resp = llm.invoke(f\"Improve this content to be more engaging:\\n\\n{state['content']}\")\n",
    "    return {\"content\": resp.content, \"iteration\": state[\"iteration\"] + 1}\n",
    "\n",
    "def finalize_content(state: QualityState) -> dict:\n",
    "    return {\"final_content\": state[\"content\"], \"feedback\": f\"Approved after {state['iteration']} iterations\"}\n",
    "\n",
    "def should_continue(state: QualityState) -> Literal[\"improve\", \"finalize\"]:\n",
    "    if state[\"quality_score\"] >= 7 or state[\"iteration\"] >= 3:\n",
    "        return \"finalize\"\n",
    "    return \"improve\"\n",
    "\n",
    "g = StateGraph(QualityState)\n",
    "g.add_node(\"evaluate\", evaluate_quality)\n",
    "g.add_node(\"improve\",  improve_content)\n",
    "g.add_node(\"finalize\", finalize_content)\n",
    "\n",
    "g.add_edge(START, \"evaluate\")\n",
    "g.add_conditional_edges(\"evaluate\", should_continue, {\"improve\": \"improve\", \"finalize\": \"finalize\"})\n",
    "g.add_edge(\"improve\", \"evaluate\")  # <-- the loop-back edge\n",
    "g.add_edge(\"finalize\", END)\n",
    "\n",
    "result = g.compile().invoke({\"content\": \"AI is cool\", \"quality_score\": 0, \"feedback\": \"\", \"final_content\": \"\", \"iteration\": 0})\n",
    "\n",
    "print(f\"Original:    AI is cool\")\n",
    "print(f\"Final:       {result['final_content'][:200]}\")\n",
    "print(f\"Feedback:    {result['feedback']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Self-Correcting Code Generator\n",
    "\n",
    "A classic agentic loop: **generate → validate → (loop if error)**\n",
    "\n",
    "The `validate_code` node actually **executes** the generated code against test cases. If it fails, the error message is passed back to `generate_code` as feedback."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class CodeGenState(TypedDict):\n",
    "    task: str\n",
    "    code: str\n",
    "    errors: Annotated[list[str], operator.add]\n",
    "    iteration: int\n",
    "    max_iterations: int\n",
    "    success: bool\n",
    "\n",
    "def generate_code(state: CodeGenState) -> dict:\n",
    "    if state[\"iteration\"] == 0:\n",
    "        prompt = f\"Write Python code for: {state['task']}\\nReturn only the code.\"\n",
    "    else:\n",
    "        prompt = f\"Fix this Python code:\\n{state['code']}\\n\\nErrors:\\n{state['errors'][-1]}\\n\\nReturn only the corrected code.\"\n",
    "\n",
    "    code = llm.invoke(prompt).content.strip()\n",
    "    if code.startswith(\"```\"):\n",
    "        code = code.split(\"```\")[1]\n",
    "        if code.startswith(\"python\"): code = code[6:]\n",
    "    return {\"code\": code, \"iteration\": state[\"iteration\"] + 1}\n",
    "\n",
    "def validate_code(state: CodeGenState) -> dict:\n",
    "    try:\n",
    "        compile(state[\"code\"], \"<string>\", \"exec\")\n",
    "    except SyntaxError as e:\n",
    "        return {\"errors\": [f\"SyntaxError: {e}\"], \"success\": False}\n",
    "\n",
    "    namespace = {}\n",
    "    try:\n",
    "        exec(state[\"code\"], namespace)\n",
    "    except Exception as e:\n",
    "        return {\"errors\": [f\"Runtime error: {e}\"], \"success\": False}\n",
    "\n",
    "    return {\"success\": True}\n",
    "\n",
    "def should_continue(state: CodeGenState) -> Literal[\"generate\", \"end\"]:\n",
    "    if state[\"success\"] or state[\"iteration\"] >= state[\"max_iterations\"]:\n",
    "        return \"end\"\n",
    "    return \"generate\"\n",
    "\n",
    "g = StateGraph(CodeGenState)\n",
    "g.add_node(\"generate\", generate_code)\n",
    "g.add_node(\"validate\", validate_code)\n",
    "\n",
    "g.add_edge(START, \"generate\")\n",
    "g.add_edge(\"generate\", \"validate\")\n",
    "g.add_conditional_edges(\"validate\", should_continue, {\"generate\": \"generate\", \"end\": END})\n",
    "\n",
    "result = g.compile().invoke({\n",
    "    \"task\": \"a function named 'factorial' that computes factorial recursively\",\n",
    "    \"code\": \"\", \"errors\": [], \"iteration\": 0, \"max_iterations\": 3, \"success\": False,\n",
    "})\n",
    "\n",
    "print(f\"Success: {result['success']}  |  Iterations: {result['iteration']}\")\n",
    "print(f\"\\nFinal Code:\\n{result['code']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Iterative Research Loop\n",
    "\n",
    "The graph digs deeper into a topic — each iteration generates a follow-up question, then researches it. When `max_depth` is reached, it synthesizes all findings."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ResearchState(TypedDict):\n",
    "    topic: str\n",
    "    findings: Annotated[list[str], operator.add]\n",
    "    questions: list[str]\n",
    "    iteration: int\n",
    "    max_depth: int\n",
    "    summary: str\n",
    "\n",
    "def research(state: ResearchState) -> dict:\n",
    "    if state[\"iteration\"] == 0:\n",
    "        query = f\"Give me 3 key facts about: {state['topic']}\"\n",
    "    else:\n",
    "        question = state[\"questions\"][-1] if state[\"questions\"] else \"elaborate\"\n",
    "        query = f\"Based on: {state['findings'][-1]}\\n\\nGo deeper: {question}\"\n",
    "    return {\"findings\": [llm.invoke(query).content]}\n",
    "\n",
    "def generate_questions(state: ResearchState) -> dict:\n",
    "    resp = llm.invoke(f\"Based on this finding:\\n{state['findings'][-1]}\\n\\nWhat's one deeper question? Reply with just the question.\")\n",
    "    return {\"questions\": [resp.content], \"iteration\": state[\"iteration\"] + 1}\n",
    "\n",
    "def synthesize(state: ResearchState) -> dict:\n",
    "    all_findings = \"\\n\\n\".join(state[\"findings\"])\n",
    "    resp = llm.invoke(f\"Synthesize these findings into a coherent summary:\\n\\n{all_findings}\")\n",
    "    return {\"summary\": resp.content}\n",
    "\n",
    "def should_continue(state: ResearchState) -> Literal[\"research\", \"synthesize\"]:\n",
    "    return \"synthesize\" if state[\"iteration\"] >= state[\"max_depth\"] else \"research\"\n",
    "\n",
    "g = StateGraph(ResearchState)\n",
    "g.add_node(\"research\",   research)\n",
    "g.add_node(\"questions\",  generate_questions)\n",
    "g.add_node(\"synthesize\", synthesize)\n",
    "\n",
    "g.add_edge(START, \"research\")\n",
    "g.add_edge(\"research\", \"questions\")\n",
    "g.add_conditional_edges(\"questions\", should_continue, {\"research\": \"research\", \"synthesize\": \"synthesize\"})\n",
    "g.add_edge(\"synthesize\", END)\n",
    "\n",
    "result = g.compile().invoke({\n",
    "    \"topic\": \"quantum computing applications\",\n",
    "    \"findings\": [], \"questions\": [], \"iteration\": 0, \"max_depth\": 2, \"summary\": \"\",\n",
    "})\n",
    "\n",
    "print(f\"Depth: {result['iteration']}  |  Findings: {len(result['findings'])}\")\n",
    "print(f\"\\nSummary:\\n{result['summary']}\")"
   ]
  }
 ],
